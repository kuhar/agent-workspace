#!/bin/bash
# Sandboxed agent runner using bwrap (bubblewrap).
#
# Restricts the agent to read-write access on a single project directory
# while providing read-only access to system tools and agent runtimes.
# The entire home directory is mounted read-only, with specific paths
# overlaid as read-write where the selected harness needs to persist state.
#
# SETUP (one-time, requires sudo):
#   Ubuntu 24.04+ blocks unprivileged user namespaces via AppArmor.
#   Run setup-bwrap-apparmor.sh from this directory.
#
# Usage:
#   agent-sandbox [--harness claude|opencode|codex] [--im-feeling-lucky] [--airgap|--no-network] [project-dir] [-- harness-args...]
#   agent-sandbox claude|opencode|codex [--im-feeling-lucky] [--airgap|--no-network] [project-dir] [-- harness-args...]
#
# Examples:
#   agent-sandbox ~/iree/constraints
#   agent-sandbox ~/iree/constraints -- -p "fix the build"
#   agent-sandbox --harness opencode ~/iree/constraints
#   agent-sandbox codex ~/iree/constraints -- "fix the build"
#   agent-sandbox --im-feeling-lucky ~/iree/constraints
#   agent-sandbox  # uses current directory

set -euo pipefail

# --- Parse arguments ---
usage() {
    cat <<'EOF'
Usage:
  agent-sandbox [--harness claude|opencode|codex] [--im-feeling-lucky] [--airgap|--no-network] [project-dir] [-- harness-args...]
  agent-sandbox claude|opencode|codex [--im-feeling-lucky] [--airgap|--no-network] [project-dir] [-- harness-args...]

Options:
  --harness, -H NAME       Select claude, opencode, or codex (default: claude)
  --im-feeling-lucky      Use real gh/git/ssh credentials instead of sandbox credentials
  --airgap, --no-network  Disable shell command networking and Codex web tools
  -h, --help              Show this help

Examples:
  agent-sandbox ~/iree/constraints
  agent-sandbox --harness opencode ~/iree/constraints
  agent-sandbox codex ~/iree/constraints -- "fix the build"
  agent-sandbox opencode ~/iree/constraints -- run "fix the build"
EOF
}

PROJECT_DIR=""
HARNESS="claude"
HARNESS_ARGS=()
IM_FEELING_LUCKY=false
AIRGAP=false

script_name="$(basename "$0")"
case "$script_name" in
    opencode-sandbox) HARNESS="opencode" ;;
    codex-sandbox) HARNESS="codex" ;;
esac

while [[ $# -gt 0 ]]; do
    case "$1" in
        --harness|-H)
            if [[ $# -lt 2 ]]; then
                echo "Error: $1 requires a harness name" >&2
                exit 1
            fi
            HARNESS="$2"
            shift 2
            ;;
        --harness=*)
            HARNESS="${1#*=}"
            shift
            ;;
        --im-feeling-lucky)
            IM_FEELING_LUCKY=true
            shift
            ;;
        --airgap|--no-network)
            AIRGAP=true
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        --)
            shift
            HARNESS_ARGS=("$@")
            break
            ;;
        *)
            if [[ -z "$PROJECT_DIR" && ( "$1" == "claude" || "$1" == "opencode" || "$1" == "codex" ) && ! -d "$1" ]]; then
                HARNESS="$1"
            elif [[ -z "$PROJECT_DIR" ]]; then
                PROJECT_DIR="$1"
            else
                echo "Error: unexpected argument '$1'" >&2
                usage >&2
                exit 1
            fi
            shift
            ;;
    esac
done

case "$HARNESS" in
    claude|opencode|codex) ;;
    *)
        echo "Error: unknown harness '$HARNESS' (expected claude, opencode, or codex)" >&2
        exit 1
        ;;
esac

PROJECT_DIR="$(realpath "${PROJECT_DIR:-.}")"

if [[ ! -d "$PROJECT_DIR" ]]; then
    echo "Error: '$PROJECT_DIR' is not a directory" >&2
    exit 1
fi

has_arg() {
    local needle="$1"
    shift

    local arg
    for arg in "$@"; do
        [[ "$arg" == "$needle" ]] && return 0
    done

    return 1
}

codex_airgap_blocks_feature() {
    case "$1" in
        browser_use|browser_use_external|computer_use|image_generation|in_app_browser|standalone_web_search|search_tool|web_search_cached|web_search_request)
            return 0
            ;;
    esac

    return 1
}

codex_airgap_config_enables_blocked_feature() {
    local config="$1"
    local compact="${config//[[:space:]]/}"
    local feature

    for feature in browser_use browser_use_external computer_use image_generation in_app_browser standalone_web_search search_tool web_search_cached web_search_request; do
        case "$compact" in
            "features.$feature=true"|"features.$feature=1")
                return 0
                ;;
        esac
    done

    case "$compact" in
        "web_search=\"live\""|"web_search='live'"|"web_search=live"|"web_search=\"cached\""|"web_search='cached'"|"web_search=cached"|"web_search=true"|"web_search=1")
            return 0
            ;;
    esac

    return 1
}

resolve_command() {
    local env_name="$1"
    local fallback="$2"
    local resolved="${!env_name:-}"

    if [[ -z "$resolved" ]]; then
        resolved="$(command -v "$fallback" || true)"
    fi

    if [[ -z "$resolved" ]]; then
        case "$fallback" in
            claude) resolved="$HOME/.local/bin/claude" ;;
            opencode) resolved="$HOME/.opencode/bin/opencode" ;;
            codex) resolved="codex" ;;
        esac
    fi

    if [[ "$resolved" == */* && ! -x "$resolved" ]]; then
        echo "Error: $fallback not found at '$resolved' (set $env_name to override)." >&2
        exit 1
    fi

    if [[ "$resolved" != */* ]] && ! command -v "$resolved" >/dev/null 2>&1; then
        echo "Error: $fallback not found (set $env_name to override)." >&2
        exit 1
    fi

    printf '%s\n' "$resolved"
}

# --- Harness command ---
AGENT_CMD=()
case "$HARNESS" in
    claude)
        CLAUDE_BIN="$(resolve_command CLAUDE_BIN claude)"
        AGENT_CMD=("$CLAUDE_BIN" --dangerously-skip-permissions "${HARNESS_ARGS[@]}")
        ;;
    opencode)
        OPENCODE_BIN="$(resolve_command OPENCODE_BIN opencode)"
        OPENCODE_ARGS=("${HARNESS_ARGS[@]}")
        if [[ "${OPENCODE_ARGS[0]:-}" == "run" ]] \
            && ! has_arg --dangerously-skip-permissions "${OPENCODE_ARGS[@]}" \
            && ! has_arg --help "${OPENCODE_ARGS[@]}" \
            && ! has_arg -h "${OPENCODE_ARGS[@]}"; then
            OPENCODE_ARGS=(run --dangerously-skip-permissions "${OPENCODE_ARGS[@]:1}")
        fi
        AGENT_CMD=("$OPENCODE_BIN" "${OPENCODE_ARGS[@]}")
        ;;
    codex)
        CODEX_BIN="$(resolve_command CODEX_BIN codex)"
        CODEX_ARGS=()
        CODEX_HAS_CD=false
        CODEX_HAS_SANDBOX_OVERRIDE=false
        CODEX_HAS_APPROVAL_OVERRIDE=false
        CODEX_AIRGAP_UNSAFE_OVERRIDE=false
        CODEX_AIRGAP_WEB_TOOL_OVERRIDE=false
        CODEX_EXPECTS_SANDBOX_VALUE=false
        CODEX_EXPECTS_ENABLE_VALUE=false
        CODEX_EXPECTS_CONFIG_VALUE=false
        for arg in "${HARNESS_ARGS[@]}"; do
            if $CODEX_EXPECTS_SANDBOX_VALUE; then
                [[ "$arg" == "danger-full-access" ]] && CODEX_AIRGAP_UNSAFE_OVERRIDE=true
                CODEX_EXPECTS_SANDBOX_VALUE=false
                continue
            fi
            if $CODEX_EXPECTS_ENABLE_VALUE; then
                if codex_airgap_blocks_feature "$arg"; then
                    CODEX_AIRGAP_WEB_TOOL_OVERRIDE=true
                fi
                CODEX_EXPECTS_ENABLE_VALUE=false
                continue
            fi
            if $CODEX_EXPECTS_CONFIG_VALUE; then
                if codex_airgap_config_enables_blocked_feature "$arg"; then
                    CODEX_AIRGAP_WEB_TOOL_OVERRIDE=true
                fi
                CODEX_EXPECTS_CONFIG_VALUE=false
                continue
            fi

            case "$arg" in
                --cd|--cd=*|-C) CODEX_HAS_CD=true ;;
                --search) CODEX_AIRGAP_WEB_TOOL_OVERRIDE=true ;;
                --enable) CODEX_EXPECTS_ENABLE_VALUE=true ;;
                --enable=*)
                    if codex_airgap_blocks_feature "${arg#*=}"; then
                        CODEX_AIRGAP_WEB_TOOL_OVERRIDE=true
                    fi
                    ;;
                -c|--config) CODEX_EXPECTS_CONFIG_VALUE=true ;;
                --config=*)
                    if codex_airgap_config_enables_blocked_feature "${arg#*=}"; then
                        CODEX_AIRGAP_WEB_TOOL_OVERRIDE=true
                    fi
                    ;;
                --sandbox|-s)
                    CODEX_HAS_SANDBOX_OVERRIDE=true
                    CODEX_EXPECTS_SANDBOX_VALUE=true
                    ;;
                --sandbox=*)
                    CODEX_HAS_SANDBOX_OVERRIDE=true
                    [[ "${arg#*=}" == "danger-full-access" ]] && CODEX_AIRGAP_UNSAFE_OVERRIDE=true
                    ;;
                --full-auto)
                    CODEX_HAS_SANDBOX_OVERRIDE=true
                    CODEX_HAS_APPROVAL_OVERRIDE=true
                    ;;
                --dangerously-bypass-approvals-and-sandbox)
                    CODEX_HAS_SANDBOX_OVERRIDE=true
                    CODEX_AIRGAP_UNSAFE_OVERRIDE=true
                    ;;
                --ask-for-approval|--ask-for-approval=*|-a) CODEX_HAS_APPROVAL_OVERRIDE=true ;;
            esac
        done
        if $AIRGAP && $CODEX_AIRGAP_UNSAFE_OVERRIDE; then
            echo "Error: codex airgap mode needs Codex's command sandbox; remove danger-full-access/bypass overrides." >&2
            exit 1
        fi
        if $AIRGAP && $CODEX_AIRGAP_WEB_TOOL_OVERRIDE; then
            echo "Error: codex airgap mode disables Codex web/search/browser tools; remove --search or blocked feature overrides." >&2
            exit 1
        fi
        if ! $CODEX_HAS_CD; then
            CODEX_ARGS+=(--cd "$PROJECT_DIR")
        fi
        if $AIRGAP; then
            CODEX_ARGS+=(-c 'web_search="disabled"')
            for feature in browser_use browser_use_external computer_use image_generation in_app_browser standalone_web_search search_tool; do
                CODEX_ARGS+=(--disable "$feature")
            done
            if ! $CODEX_HAS_SANDBOX_OVERRIDE; then
                CODEX_ARGS+=(--sandbox workspace-write)
            fi
            if ! $CODEX_HAS_APPROVAL_OVERRIDE; then
                CODEX_ARGS+=(--ask-for-approval never)
            fi
        elif ! $CODEX_HAS_SANDBOX_OVERRIDE; then
            CODEX_ARGS+=(--dangerously-bypass-approvals-and-sandbox)
        fi
        CODEX_ARGS+=("${HARNESS_ARGS[@]}")
        AGENT_CMD=("$CODEX_BIN" "${CODEX_ARGS[@]}")
        ;;
esac

# --- Preflight check ---
if ! /usr/bin/bwrap --ro-bind / / -- true 2>/dev/null; then
    echo "Error: bwrap cannot create user namespaces." >&2
    echo "Run the one-time AppArmor setup (see setup-bwrap-apparmor.sh next to this script)." >&2
    exit 1
fi

if $IM_FEELING_LUCKY; then
    echo "🎲 Sandboxed $HARNESS (with real credentials) in: $PROJECT_DIR"
else
    echo "Sandboxed $HARNESS in: $PROJECT_DIR"
fi
if $AIRGAP; then
    if [[ "$HARNESS" == "codex" ]]; then
        echo "  Network: enabled for codex control plane; Codex web tools disabled; shell commands use Codex sandbox"
    else
        echo "  Network: disabled"
    fi
fi

# --- Detect git worktrees with git dirs outside the project ---
GIT_DIR_BINDS=()
add_git_dir_bind() {
    local label="$1"
    local path="$2"
    local existing

    [[ -d "$path" ]] || return 0
    case "$path" in "$PROJECT_DIR"/*) return 0 ;; esac
    for existing in "${GIT_DIR_BIND_PATHS[@]}"; do
        [[ "$existing" == "$path" ]] && return 0
    done

    GIT_DIR_BIND_PATHS+=("$path")
    GIT_DIR_BINDS+=(--bind "$path" "$path")
    echo "  $label: $path"
}

GIT_DIR_BIND_PATHS=()
for gitfile in "$PROJECT_DIR/.git" "$PROJECT_DIR"/*/.git; do
    [[ -f "$gitfile" ]] || continue
    repo_dir="$(dirname "$gitfile")"
    git_dir="$(cd "$repo_dir" && realpath "$(git rev-parse --git-dir)" 2>/dev/null)" || continue
    git_common_dir="$(cd "$repo_dir" && realpath "$(git rev-parse --git-common-dir)" 2>/dev/null)" || continue
    add_git_dir_bind "Worktree git dir" "$git_dir"
    add_git_dir_bind "Worktree common git dir" "$git_common_dir"
done

if [[ "$HARNESS" == "codex" && ${#GIT_DIR_BIND_PATHS[@]} -gt 0 ]]; then
    CODEX_ADD_DIR_ARGS=()
    for path in "${GIT_DIR_BIND_PATHS[@]}"; do
        CODEX_ADD_DIR_ARGS+=(--add-dir "$path")
    done
    AGENT_CMD=("${AGENT_CMD[0]}" "${CODEX_ADD_DIR_ARGS[@]}" "${AGENT_CMD[@]:1}")
fi

# --- Build bwrap command ---
# On this system /bin, /lib, /lib64 are symlinks into /usr, so binding
# /usr and recreating the symlinks is sufficient for all system tools.

path_exists() {
    [[ -e "$1" || -L "$1" ]]
}

add_bind_if_exists() {
    local mode="$1"
    local source="$2"
    local dest="${3:-$source}"

    path_exists "$source" || return 0

    if [[ -d "$source" ]]; then
        BWRAP_ARGS+=("$mode" "$source" "$dest")
        return 0
    fi

    # File mount destinations do not exist under the private home tmpfs yet.
    # Data binds create the file inside the sandbox without exposing its parent.
    case "$mode" in
        --ro-bind)
            add_file_data_bind --ro-bind-data "$source" "$dest"
            ;;
        --bind)
            add_file_data_bind --bind-data "$source" "$dest"
            ;;
        *)
            BWRAP_ARGS+=("$mode" "$source" "$dest")
            ;;
    esac
}

add_file_data_bind() {
    local mode="$1"
    local source="$2"
    local dest="$3"
    local fd

    [[ -r "$source" ]] || return 0

    exec {fd}<"$source"
    BWRAP_DATA_FDS+=("$fd")
    BWRAP_ARGS+=("$mode" "$fd" "$dest")
}

add_env_if_set() {
    local name="$1"

    if [[ ${!name+x} ]]; then
        BWRAP_ARGS+=(--setenv "$name" "${!name}")
    fi
}

BWRAP_DATA_FDS=()
BWRAP_ARGS=(
    --ro-bind /usr /usr
    --symlink usr/bin /bin
    --symlink usr/lib /lib
    --symlink usr/lib64 /lib64
    --ro-bind /etc /etc
    --proc /proc
    --ro-bind /sys /sys
    --dev /dev
    --dev-bind-try /dev/dri /dev/dri
    --dev-bind-try /dev/kfd /dev/kfd
    --dev-bind-try /dev/nvidia0 /dev/nvidia0
    --dev-bind-try /dev/nvidiactl /dev/nvidiactl
    --dev-bind-try /dev/nvidia-uvm /dev/nvidia-uvm
    --dev-bind-try /dev/nvidia-uvm-tools /dev/nvidia-uvm-tools
    --dev-bind-try /dev/nvidia-modeset /dev/nvidia-modeset
)

add_bind_if_exists --ro-bind /opt /opt
# Codex needs network for its control plane. In airgap mode, keep the parent
# Codex process online, disable native web tools, and rely on Codex's command
# sandbox for shell commands.
if $AIRGAP && [[ "$HARNESS" != "codex" ]]; then
    BWRAP_ARGS+=(--unshare-net --tmpfs /tmp)
else
    BWRAP_ARGS+=(--bind /tmp /tmp)
    add_bind_if_exists --ro-bind /run/systemd/resolve /run/systemd/resolve
fi

# --- Home dotfiles (read-only) ---
BWRAP_ARGS+=(--tmpfs "$HOME")
for path in \
    "$HOME/.bash_aliases" \
    "$HOME/.bashrc" \
    "$HOME/.cargo" \
    "$HOME/.config" \
    "$HOME/.gitconfig" \
    "$HOME/.git-hooks" \
    "$HOME/.git-confidential-patterns" \
    "$HOME/.local" \
    "$HOME/.nvm" \
    "$HOME/.profile" \
    "$HOME/.rustup" \
    "$HOME/.tmux" \
    "$HOME/go"; do
    add_bind_if_exists --ro-bind "$path" "$path"
done

# --- Credential binds (real vs sandbox) ---
if $IM_FEELING_LUCKY; then
    add_bind_if_exists --ro-bind "$HOME/.config/gh" "$HOME/.config/gh"
    add_bind_if_exists --ro-bind "$HOME/.gitconfig.local" "$HOME/.gitconfig.local"
    add_bind_if_exists --ro-bind "$HOME/.ssh" "$HOME/.ssh"
else
    add_bind_if_exists --bind "$HOME/.config/gh-sandbox" "$HOME/.config/gh"
    add_bind_if_exists --ro-bind "$HOME/.gitconfig-sandbox.local" "$HOME/.gitconfig.local"
    add_bind_if_exists --ro-bind "$HOME/.ssh-sandbox" "$HOME/.ssh"
fi

# --- Symlink targets needed by dotfiles and ~/.claude/agents ---
for path in \
    "$HOME/jakub-env" \
    "$HOME/bin"; do
    add_bind_if_exists --ro-bind "$path" "$path"
done

for path in \
    "$HOME/llvm" \
    "$HOME/iree" \
    "$HOME/rocjitsu" \
    "$HOME/reviews"; do
    add_bind_if_exists --bind "$path" "$path"
done

# --- Read-write overlays ---
BWRAP_ARGS+=(--bind "$PROJECT_DIR" "$PROJECT_DIR")
BWRAP_ARGS+=("${GIT_DIR_BINDS[@]}")
for path in \
    "$HOME/projects" \
    "$HOME/.cache" \
    "$HOME/.ccache" \
    "$HOME/.claude" \
    "$HOME/.claude.json" \
    "$HOME/.opencode" \
    "$HOME/.config/opencode" \
    "$HOME/.codex" \
    "$HOME/.local/state/claude" \
    "$HOME/.local/share/opencode"; do
    add_bind_if_exists --bind "$path" "$path"
done

# --- Environment ---
BWRAP_ARGS+=(
    --clearenv
    --setenv HOME "$HOME"
    --setenv USER "${USER:-$(id -un)}"
    --setenv LOGNAME "${LOGNAME:-${USER:-$(id -un)}}"
    --setenv SHELL "${SHELL:-/bin/bash}"
    --setenv PATH "$HOME/.local/bin:$HOME/.opencode/bin:$HOME/bin:$HOME/.nvm/versions/node/v22.14.0/bin:/usr/local/bin:/usr/bin:/bin"
)

for name in \
    LANG \
    LC_ALL \
    LC_CTYPE \
    TZ \
    TERM \
    COLORTERM \
    NO_COLOR \
    EDITOR \
    VISUAL \
    PAGER \
    LESS \
    BAT_THEME \
    GH_PAGER \
    GIT_PAGER \
    BROWSER \
    NVM_DIR \
    NVM_BIN \
    NVM_INC \
    NVM_CD_FLAGS \
    JAKUB_ENV_DIR \
    ANTHROPIC_API_KEY \
    OPENAI_API_KEY; do
    add_env_if_set "$name"
done

BWRAP_ARGS+=(
    --chdir "$PROJECT_DIR"
    --die-with-parent
    --
)

exec /usr/bin/bwrap "${BWRAP_ARGS[@]}" "${AGENT_CMD[@]}"
